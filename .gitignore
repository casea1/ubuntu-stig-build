# Ansible Galaxy roles pulled at build time (installed via requirements.yml)
roles/UBUNTU24-STIG/

# OpenSCAP scan artifacts (generated on target, not source)
*.arf.xml
stig-report-*.html
stig-viewer-*.xml
/var/log/stig-scan/

# Ansible runtime noise
*.retry
.ansible/

# Editor / OS cruft
.vscode/
.DS_Store
*.swp

# Secrets must NEVER be committed (this repo is public). Supply the LUKS
# passphrase out-of-band via luks_passphrase_file; vault files / secret drops are
# blocked here as a safety net so they can't be added by accident.
vault.yml
vault*.yml
*vault*.yml
group_vars/vault*
*.vault
secrets.yml
*.secret
*luks*passphrase*
*.key

# Managed by ansible (ai_compose) -- values from site.yml / auto-generated.
# Root-only (0600). Referenced by docker-compose.yaml via ${VAR}.
# -------- auto-generated + persisted, nothing to type --------
POSTGRES_PASSWORD={{ ai_pgvector_password }}
WEBUI_SECRET_KEY={{ ai_webui_secret_key }}
# -------- site values (set in /etc/stig-build/site.yml) --------
OI_ORIGIN={{ ai_webui_cors_origin | default('*') }}
# Open WebUI audit trail: METADATA (default) | REQUEST | REQUEST_RESPONSE | NONE
AUDIT_LOG_LEVEL={{ ai_webui_audit_log_level | default('METADATA') }}
# oikb -> Open WebUI + data sources (API key/token out-of-band, empty = oikb idle)
OPEN_WEBUI_URL={{ ai_oikb_openwebui_url | default('http://open-webui:8080') }}
OPEN_WEBUI_API_KEY={{ ai_oikb_openwebui_api_key | default('') }}
GITLAB_URL={{ ai_oikb_gitlab_url | default('') }}
GITLAB_TOKEN={{ ai_oikb_gitlab_token | default('') }}

# Managed by ansible (ai_stack role). SECRETS -- 0600, root-only, NEVER committed.
# Docker Compose reads this file automatically and interpolates ${VAR} references
# in docker-compose.yml. Regenerated idempotently: the passwords are stable across
# re-runs (persisted under {{ ai_stack_secrets_dir }}).
{% if 'pgvector' in server_tools %}
POSTGRES_PASSWORD={{ _pg_password }}
{% endif %}
{% if 'open_webui' in server_tools %}
WEBUI_SECRET_KEY={{ _webui_secret }}
{% endif %}
{% if 'vllm' in server_tools %}
HF_TOKEN={{ _hf_token }}
{% endif %}

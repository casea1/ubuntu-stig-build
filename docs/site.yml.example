# =============================================================================
# EXAMPLE per-node / site override file.
#
# Copy this to  /etc/stig-build/site.yml  ON THE BOX (root-only), one per node,
# with values for THAT machine. The playbook (local.yml) auto-loads it and its
# values BEAT group_vars/all.yml -- so per-node settings and anything you don't
# want in the public repo (internal IPs, certs) stay on the box, out of git.
#
#   sudo install -d -m 0755 /etc/stig-build
#   sudo cp site.yml /etc/stig-build/site.yml && sudo chmod 0644 /etc/stig-build/site.yml
#   # then re-run the pull (or bootstrap) and it takes effect.
#
# Override any group_vars/all.yml variable here. Common ones below.
# =============================================================================

# ---- Host firewall openings (ai profile) ------------------------------------
# USG leaves ufw default-deny inbound; open exactly what THIS node serves, and
# restrict cross-node ports to the peer's IP with `from:`.
#
# --- System 1 (UI/text-gen, e.g. 192.168.1.102): Open WebUI + Grafana ---
# ai_firewall_allow_ports:
#   - { port: 3000, proto: tcp, rule: allow }                          # Open WebUI (users)
#   - { port: 3001, proto: tcp, rule: allow, from: "192.168.1.0/24" }  # Grafana/LGTM (admins)
#   - { port: 8081, proto: tcp, rule: allow, from: "192.168.1.0/24" }  # oikb (admins)
#
# --- System 2 (extraction, e.g. 192.168.1.106): serves System 1 only ---
# ai_firewall_allow_ports:
#   - { port: 5001, proto: tcp, rule: allow, from: "192.168.1.102" }   # Docling <- System 1
#   - { port: 9998, proto: tcp, rule: allow, from: "192.168.1.102" }   # Tika    <- System 1

# ---- AI docker-compose stack (ai profile) -----------------------------------
# HANDS-OFF BY DEFAULT: on the ai profile the stack is enabled automatically, the
# node role is picked from the HOSTNAME (dev-ai1->system1, dev-ai2->system2), the
# DB password + Open WebUI secret key are auto-generated, and the custom images
# (oikb/hfcli/repomix) are built on the box. A correctly-named box needs NOTHING
# here. Use the lines below ONLY for exceptions:
#
# --- Box not named dev-ai1/dev-ai2 -> pick the role explicitly ---
# ai_node_role: system1                    # or system2
#
# --- Already-initialised pgvector DB -> pin its existing password ---
# (Otherwise the auto-generated one won't match the DB and Open WebUI can't log in.)
# ai_pgvector_password: "<the DB's existing password>"
#
# --- Lock Open WebUI's CORS to your domain (default is '*') ---
# ai_webui_cors_origin: "https://oi.yourlab"
#
# --- oikb data-source secrets (knowledge-base sync; empty = oikb stays idle) ---
# ai_oikb_openwebui_api_key: "<Open WebUI API key>"   # created in the Open WebUI UI
# ai_oikb_gitlab_url: "https://gitlab.yourlab"
# ai_oikb_gitlab_token: "<GitLab PAT>"
#
# --- Auto-download the served model on this box (needs internet + disk) ---
# ai_model_fetch: true
# # ai_hf_token: "hf_..."                  # OPTIONAL; models are open, token only dodges rate limits
#
# --- Start the stack from Ansible (only after the model is staged) ---
# ai_compose_deploy: true
#
# --- Skip building custom images (e.g. you push them from a registry) ---
# ai_compose_build_images: false
#
# --- Turn the whole stack OFF on an ai box ---
# ai_compose_enabled: false

# ---- Time source (your enclave NTP) -----------------------------------------
# usg_chrony_servers:
#   - 10.10.99.100

# ---- Cockpit TLS cert (org-CA signed, so it passes TLS inspection) -----------
# Paste the PEM contents (out-of-band; never commit). The role installs them and
# clients that trust your CA get no warning.
# cockpit_tls_cert: |
#   -----BEGIN CERTIFICATE-----
#   ...
#   -----END CERTIFICATE-----
# cockpit_tls_key: |
#   -----BEGIN PRIVATE KEY-----
#   ...
#   -----END PRIVATE KEY-----

# ---- Anything else from group_vars/all.yml is fair game too -----------------
# e.g. cockpit_allow_from: "192.168.1.0/24"

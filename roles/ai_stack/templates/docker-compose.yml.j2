# Managed by ansible (ai_stack role) -- do NOT edit by hand.
# Rendered from server_tools = {{ server_tools }}
# Secrets ({{ '${POSTGRES_PASSWORD}, ${WEBUI_SECRET_KEY}, ${HF_TOKEN}' }}) are
# interpolated by Docker Compose from the sibling .env (0600, never committed).
name: {{ ai_stack_project }}

services:
{% if 'pgvector' in server_tools %}
  # PostgreSQL 16 + pgvector: Open WebUI's app database AND RAG vector store.
  db:
    image: {{ pgvector_image }}:{{ pgvector_image_tag }}
    restart: unless-stopped
    environment:
      POSTGRES_DB: {{ pgvector_db }}
      POSTGRES_USER: {{ pgvector_user }}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
    volumes:
      - pgdata:/var/lib/postgresql/data
    ports:
      - "127.0.0.1:{{ pgvector_port }}:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ pgvector_user }} -d {{ pgvector_db }}"]
      interval: 10s
      timeout: 5s
      retries: 5
{% endif %}
{% if 'vllm' in server_tools %}
  # vLLM: OpenAI-compatible LLM inference server. Reached by Open WebUI over the
  # internal network as http://vllm:8000/v1 (host port bound to localhost only).
  vllm:
    image: {{ vllm_image }}:{{ vllm_image_tag }}
    restart: unless-stopped
    ipc: host
    environment:
      HUGGING_FACE_HUB_TOKEN: ${HF_TOKEN}
    volumes:
      - hf-cache:/root/.cache/huggingface
    ports:
      - "127.0.0.1:{{ vllm_port }}:8000"
    command: >-
      --model {{ vllm_model }}
      --served-model-name {{ vllm_served_model_name }}
      --max-model-len {{ vllm_max_model_len }}
      --gpu-memory-utilization {{ vllm_gpu_memory_utilization }}
      --host 0.0.0.0 --port 8000{{ (' ' ~ vllm_extra_args) if vllm_extra_args else '' }}
{% if _ai_need_gpu %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
{% endif %}
{% endif %}
{% if 'docling' in server_tools %}
  # Docling: document-extraction service Open WebUI uses to ingest PDFs/DOCX/etc.
  docling:
    image: {{ (docling_image_gpu if _ai_need_gpu else docling_image_cpu) }}:{{ docling_image_tag }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ docling_port }}:5001"
{% if _ai_need_gpu %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
{% endif %}
{% endif %}
{% if 'open_webui' in server_tools %}
  # Open WebUI: the browser chat UI / RAG front-end. Published on all interfaces
  # (it is the service users reach); the STIG ufw policy must open {{ open_webui_port }}/tcp.
  open-webui:
    image: {{ open_webui_image }}:{{ open_webui_image_tag }}
    restart: unless-stopped
    ports:
      - "{{ open_webui_port }}:8080"
    environment:
      WEBUI_SECRET_KEY: ${WEBUI_SECRET_KEY}
{% if 'vllm' in server_tools %}
      OPENAI_API_BASE_URL: "http://vllm:8000/v1"
      OPENAI_API_KEY: "sk-no-key-required"
{% endif %}
{% if 'pgvector' in server_tools %}
      DATABASE_URL: "postgresql://{{ pgvector_user }}:${POSTGRES_PASSWORD}@db:5432/{{ pgvector_db }}"
      VECTOR_DB: "pgvector"
      PGVECTOR_DB_URL: "postgresql://{{ pgvector_user }}:${POSTGRES_PASSWORD}@db:5432/{{ pgvector_db }}"
{% endif %}
{% if 'docling' in server_tools %}
      CONTENT_EXTRACTION_ENGINE: "docling"
      DOCLING_SERVER_URL: "http://docling:5001"
{% endif %}
    volumes:
      - open-webui:/app/backend/data
{% if ('pgvector' in server_tools) or ('docling' in server_tools) %}
    depends_on:
{% if 'pgvector' in server_tools %}
      db:
        condition: service_healthy
{% endif %}
{% if 'docling' in server_tools %}
      docling:
        condition: service_started
{% endif %}
{% endif %}
{% endif %}
{% if ('pgvector' in server_tools) or ('vllm' in server_tools) or ('open_webui' in server_tools) %}

volumes:
{% if 'pgvector' in server_tools %}
  pgdata:
{% endif %}
{% if 'vllm' in server_tools %}
  hf-cache:
{% endif %}
{% if 'open_webui' in server_tools %}
  open-webui:
{% endif %}
{% endif %}
